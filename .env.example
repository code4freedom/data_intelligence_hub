# PostgreSQL
POSTGRES_USER=rvtools
POSTGRES_PASSWORD=CHANGE_ME_postgres_secret
POSTGRES_DB=rvtools
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_neo4j_secret

# MinIO / S3
MINIO_ROOT_USER=CHANGE_ME_minio_user
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_secret
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=CHANGE_ME_minio_user
S3_SECRET_KEY=CHANGE_ME_minio_secret
S3_BUCKET=rvtools

# Redis
REDIS_URL=redis://redis:6379

# Application
APP_MAPPING_CSV=/app/tools/app_mapping.example.csv
REPORT_AUTHOR=Your Name
MAX_UPLOAD_SIZE_MB=100
